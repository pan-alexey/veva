{
  "include": ["src/**/*"],
  "compilerOptions": {
    "target": "es5",
    "module": "commonjs",
    "lib": ["es2017", "es7", "es6", "dom"],
    "noImplicitAny": true,
    "sourceMap": false,
    "outDir": "dist",
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true
  },
  "exclude": ["node_modules", "dist"]
}
